---
import Base from "../layouts/Base.astro";
import Email from "../components/Email.astro";
import { loadMembers } from "../lib/members";

const members = loadMembers();
---

<Base title="Team · SoDA Lab">
  <header class="mb-10">
    <h1 class="text-3xl font-semibold tracking-tight">Team</h1>
    <p class="mt-2 text-zinc-600">The people behind SoDA Lab.</p>
  </header>

  <section class="mb-14">
    <h2 class="mb-6 text-sm font-semibold uppercase tracking-wider text-zinc-500">Faculty</h2>
    <div class="grid gap-8 sm:grid-cols-2">
      {members.faculty.map((f) => (
        <article class="flex gap-5">
          {f.photo && (
            <img
              src={`/teampic/${f.photo}`}
              alt={f.name}
              class="h-32 w-32 shrink-0 rounded-lg object-cover ring-1 ring-zinc-200"
              loading="lazy"
            />
          )}
          <div class="min-w-0">
            <h3 class="text-lg font-semibold text-zinc-900">{f.name}</h3>
            <p class="text-sm text-zinc-600">{f.role}</p>
            <ul class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm">
              {f.website && <li><a href={f.website} class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">Website</a></li>}
              {f.scholar && <li><a href={f.scholar} class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">Scholar</a></li>}
              {f.cv && <li><a href={f.cv} class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">CV</a></li>}
              {f.email && (
                <li>
                  <Email
                    user={f.email.split("@")[0]}
                    host={f.email.split("@")[1]}
                    class="text-[var(--color-accent)] hover:underline"
                  />
                </li>
              )}
            </ul>
            {f.education && f.education.length > 0 && (
              <div class="mt-3 text-sm text-zinc-600">
                <div class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Background</div>
                <ul class="mt-1.5 space-y-1">
                  {f.education.map((e) => <li set:html={`• ${e}`} />)}
                </ul>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mb-14">
    <h2 class="mb-6 text-sm font-semibold uppercase tracking-wider text-zinc-500">PhD Students</h2>
    <ul class="grid gap-x-6 gap-y-3 sm:grid-cols-2 lg:grid-cols-3">
      {members.phd_students.map((s) => (
        <li class="flex items-center gap-3">
          <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-zinc-100 text-xs font-medium text-zinc-500">
            {/* Strip parenthetical nicknames like "Shirui (Olivia) Zhou" so
                the initials don't include "(". Then take the first letter of
                each remaining word, up to two. */}
            {s.name.replace(/\([^)]*\)/g, " ").split(/\s+/).filter(Boolean).map((w) => w[0]).slice(0, 2).join("")}
          </div>
          <div class="min-w-0">
            <div class="text-sm font-medium text-zinc-900">{s.name}</div>
            {s.website && <a href={s.website} class="text-xs text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">website</a>}
          </div>
        </li>
      ))}
    </ul>
  </section>

  {members.visitors.length > 0 && (
    <section class="mb-14">
      <h2 class="mb-6 text-sm font-semibold uppercase tracking-wider text-zinc-500">Visitors</h2>
      <ul class="space-y-2 text-sm text-zinc-700">
        {members.visitors.map((v) => (
          <li>
            {v.name}
            {v.affiliation && <span class="text-zinc-500"> · {v.affiliation}</span>}
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="border-t border-zinc-200 pt-10">
    <h2 class="mb-6 text-sm font-semibold uppercase tracking-wider text-zinc-500">Alumni</h2>

    <div class="space-y-6 text-sm">
      <div>
        <h3 class="mb-2 font-medium text-zinc-900">Postdoctoral researchers</h3>
        <ul class="space-y-1 text-zinc-700">
          {members.alumni.postdocs.map((a) => (
            <li>
              {a.website ? (
                <a href={a.website} class="hover:text-[var(--color-accent)]" target="_blank" rel="noopener">{a.name}</a>
              ) : a.name}
              {a.now && <span class="text-zinc-500"> · now {a.now}</span>}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-2 font-medium text-zinc-900">Graduate students (SMU)</h3>
        <ul class="space-y-1 text-zinc-700">
          {members.alumni.graduate_smu.map((a) => (
            <li>{a.name}{a.year && <span class="text-zinc-500"> · {a.year}</span>}</li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-2 font-medium text-zinc-900">Undergraduate students (SMU)</h3>
        <ul class="space-y-1 text-zinc-700">
          {members.alumni.undergraduate_smu.map((a) => (
            <li>{a.name}{a.year && <span class="text-zinc-500"> · {a.year}</span>}</li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-2 font-medium text-zinc-900">Visitors</h3>
        <ul class="space-y-1 text-zinc-700">
          {members.alumni.visitors.map((a) => (
            <li>{a.name}{a.year && <span class="text-zinc-500"> · {a.year}</span>}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Base>
