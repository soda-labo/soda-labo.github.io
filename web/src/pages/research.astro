                class="topic-chip"
                style={`border-color:${topicColor(tag).bg};color:${topicColor(tag).bg};`}
              >
                {topicName(tag)}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <section class="closing">
      <p>
        To see what we have been working on, browse our
        <a href="/publications">publications</a>.
      </p>
    </section>
  </div>
</Base>

