---

<Base title="Research · SoDA Lab">
  <div class="research-paper">
    <section class="hero">
      <div>
        <h1 class="hero-title">
          How <em>people</em> behave online,<br />
          and how <em>AI</em> is reshaping those spaces.
        </h1>
        <p class="hero-lede">
          We study these dynamics to help design healthier digital spaces.
        </p>
      </div>
      <div class="illo-wrap hero-illo" style="color: #b14a1f">
        <svg class="illo" viewBox="0 0 360 280" aria-hidden="true" set:html={heroIllo} />
      </div>
    </section>

    <div class="section-head">
      <span class="label">Themes</span>
      <span class="line"></span>
      <h2>what we're working on</h2>
    </div>

    {areas.map((a, i) => (
      <article class:list={["topic", i % 2 === 1 && "flip"]} style={`color: ${primaryColor(a.topics)}`}>
        <div class="illo-wrap">
          <svg class="illo" viewBox="0 0 360 280" aria-hidden="true" set:html={a.illo} />
        </div>
        <div class="copy">
          <div class="kicker"><span class="num">{a.num}</span> {a.kicker}</div>
          <h3>{a.headline}</h3>
          <p set:html={a.body} />
          <div class="topic-chips">
            <span class="chips-label">explore in publications</span>
            {a.topics.map((t) => (
              <a
                href={`/publications?topic=${t}`}
                class="topic-chip"
                style={`border-color:${topicColor(t).bg};color:${topicColor(t).bg};`}
              >
                {topicName(t)}
              </a>
            ))}
          </div>
        </div>
      </article>
    ))}

    <div class="section-head" style="margin-top: 80px;">
      <span class="label">Horizons</span>
      <span class="line"></span>
      <h2>where we're headed</h2>
    </div>

    <div class="horizons">
      {thrusts.map((t) => (
        <div class="horizon" style={`color: ${primaryColor(t.topics)}`}>
          <div class="illo-wrap">
            <svg class="illo" viewBox="0 0 280 220" aria-hidden="true" set:html={t.illo} />
          </div>
          <div class="kicker"><span class="num">{t.num}</span> {t.kicker}</div>
          <h3>{t.headline}</h3>
          <p set:html={t.body} />
          <div class="topic-chips">
