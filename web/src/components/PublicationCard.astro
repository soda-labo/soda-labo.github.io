---
import type { Publication } from "../lib/publications";
import {
  pillStyle, topicName,
  methodName, methodChipStyle,
  platformName,
} from "../lib/tag-colors";

interface Props {
  pub: Publication;
  labMembers?: string[];
}

const { pub, labMembers = ["haewoon kwak", "jisun an"] } = Astro.props;

function boldifyAuthors(authors: string): string {
  if (!authors) return "";
  return authors
    .split(/,/)
    .map((a) => {
      const trimmed = a.trim();
      const lower = trimmed.toLowerCase();
      const isLab = labMembers.some((m) => lower.includes(m));
      return isLab
        ? `<strong class="text-zinc-900">${trimmed}</strong>`
        : `<span>${trimmed}</span>`;
    })
    .join(", ");
}

const authorsHtml = boldifyAuthors(pub.authors);

const searchText = [
  pub.title,
  pub.authors,
  pub.venue,
  pub.year?.toString() ?? "",
  pub.tags.join(" "),
].join(" ").toLowerCase();
---

<article
  class="pub-card group flex gap-5 border-b border-zinc-200 py-6 last:border-b-0"
  data-tags={pub.tags.join(",")}
  data-methods={pub.methods.join(",")}
  data-platforms={pub.platforms.join(",")}
  data-year={pub.year ?? ""}
  data-citations={pub.citations}
  data-highlight={pub.highlight ? "1" : "0"}
  data-title-key={pub.title.toLowerCase()}
  data-search={searchText}
  data-uncurated={pub.uncurated ? "1" : "0"}
>
  {pub.image && (
    <div class="hidden shrink-0 sm:block">
      <img
        src={`/pubpic/${pub.image}`}
        alt=""
        class="h-28 w-28 rounded-md object-cover ring-1 ring-zinc-200"
        loading="lazy"
      />
    </div>
  )}

  <div class="min-w-0 flex-1">
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <h2 class="text-lg font-semibold leading-snug text-zinc-900">
        {pub.link?.url ? (
          <a href={pub.link.url} class="hover:text-[var(--color-accent)]" target="_blank" rel="noopener">
            {pub.title}
          </a>
        ) : (
          pub.title
        )}
      </h2>
      {pub.highlight && (
        <span class="rounded-sm bg-amber-100 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-amber-800">
          Featured
        </span>
      )}
      {pub.uncurated && (
        <span class="rounded-sm bg-zinc-100 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-zinc-500">
          New
        </span>
      )}
    </div>

    {pub.authors && (
      <p class="mt-1 text-base text-zinc-600" set:html={authorsHtml} />
    )}

    <p class="mt-1 text-base text-zinc-500">
      {pub.venue && <span class="italic">{pub.venue}</span>}
      {pub.venue && pub.year && <span class="mx-1.5">·</span>}
      {pub.year && <span>{pub.year}</span>}
      {pub.citations > 0 && (
        <>
          <span class="mx-1.5">·</span>
          <span title="Citations from Google Scholar" class="inline-flex items-baseline">
            <svg xmlns="http://www.w3.org/2000/svg" class="mr-1 inline-block h-3 w-3 self-center" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
            {pub.citations.toLocaleString()} cite{pub.citations === 1 ? "" : "s"}
          </span>
        </>
      )}
    </p>

    {pub.description && (
      <p class="mt-2 text-base leading-relaxed text-zinc-700">{pub.description}</p>
    )}

    {(pub.tags.length + pub.methods.length + pub.platforms.length) > 0 && (
      <ul class="mt-3 flex flex-wrap items-center gap-1.5">
        {/* Chips are <a> tags so they navigate to a filtered /publications
            from anywhere (home, research, etc.). On the publications page
            itself, the inline JS intercepts the click and toggles the
            filter in place without a reload. */}
        {pub.tags.map((tag) => (
          <li>
            <a
              href={`/publications?topic=${tag}`}
              data-tag-pill={tag}
              style={pillStyle(tag)}
              class="rounded-full px-2 py-0.5 text-[11px] font-medium opacity-90 hover:opacity-100"
            >
              {topicName(tag)}
            </a>
          </li>
        ))}
        {pub.methods.map((m) => (
          <li>
            <a
              href={`/publications?method=${m}`}
              data-method-pill={m}
              style={methodChipStyle(m)}
              class="rounded-full px-2 py-0.5 text-[11px] font-medium hover:opacity-80"
            >
              {methodName(m)}
            </a>
          </li>
        ))}
        {pub.platforms.map((p) => (
          <li>
            <a
              href={`/publications?platform=${p}`}
              data-platform-pill={p}
              class="rounded-full bg-zinc-100 px-2 py-0.5 text-[11px] font-medium text-zinc-600 hover:bg-zinc-200"
            >
              {platformName(p)}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</article>
